[project]
requires = ["python-3.11"]

[dev]
# 开发环境：扣子平台自动注入 DATABASE_URL（开发环境数据库）
build = ["pip", "install", "-r", "requirements.txt"]
run = ["python", "-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "5000"]

[deploy]
# 生产环境：扣子平台自动注入 DATABASE_URL（生产环境数据库）
build = ["pip", "install", "-r", "requirements.txt"]
run = ["python", "-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "5000"]
