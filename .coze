[project]
requires = ["python-3.11"]

[dev]
build = ["pip", "install", "-r", "requirements.txt"]
run = ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "5000"]

[deploy]
build = ["pip", "install", "-r", "requirements.txt"]
run = ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "5000"]
