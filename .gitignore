.env
.env.local
.env.supabase
.env.example.fc
*.pem
*.key

# 数据文件 - 不要推送（包含卡密数据）
coze_data_export.json
data_export_for_production.json
migration_export.json
*.json
!package.json
!tsconfig.json

# 备份文件
backups/

# IDE
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 日志
*.log
logs/

# 临时文件
*.tmp
*.temp
.cache/

# 数据库
*.db
*.sqlite
*.sqlite3

# 测试
.pytest_cache/
.coverage
htmlcov/
tests/

# 其他
node_modules/
.coze/
.cozeproj/

# 文档 - 不要推送
docs/
AGENTS.md

# 截图和资源文件 - 不要推送
assets/
